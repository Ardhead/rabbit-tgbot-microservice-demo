# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=messages_db

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_QUEUE=messages_queue
RABBITMQ_EXCHANGE=messages_exchange

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Service Ports
PRODUCER_PORT=3000
CONSUMER_PORT=3001
NOTIFIER_PORT=3002

# Cron Intervals
PRODUCER_CRON_INTERVAL=*/30 * * * * *
NOTIFIER_CRON_INTERVAL=*/5 * * * * *
